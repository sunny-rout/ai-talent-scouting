# ─────────────────────────────────────────────────────────────────────────────
# TalentScout AI — Environment Configuration
# Copy this file to .env and fill in the values for your chosen provider.
# ─────────────────────────────────────────────────────────────────────────────

# ── Active LLM provider ───────────────────────────────────────────────────────
# Choose one: ollama | gemini | vertex | openai | auto
#
# auto  — tries providers in order (ollama → gemini → openai → vertex)
#         and uses the first one that responds successfully.
#         Useful for environments where availability is uncertain.
#
LLM_PROVIDER=ollama

# ─────────────────────────────────────────────────────────────────────────────
# Option 1 — Ollama (local, free)
# Install: https://ollama.com   |   Run: ollama serve
# Pull a model first: ollama pull llama3
# ─────────────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
# Other good options: qwen2.5 | mistral | llama3.1 | phi3

# ─────────────────────────────────────────────────────────────────────────────
# Option 2 — Google AI Studio (Gemini API key)
# Get a free API key: https://aistudio.google.com/app/apikey
# LLM_PROVIDER=gemini
# ─────────────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
# Other options: gemini-2.0-flash-lite | gemini-1.5-pro | gemini-1.5-flash

# ─────────────────────────────────────────────────────────────────────────────
# Option 3 — Google Vertex AI (GCP project + Application Default Credentials)
# Auth: gcloud auth application-default login
# LLM_PROVIDER=vertex
# ─────────────────────────────────────────────────────────────────────────────
VERTEX_PROJECT=
VERTEX_LOCATION=us-central1
VERTEX_MODEL=gemini-2.0-flash

# ─────────────────────────────────────────────────────────────────────────────
# Option 4 — OpenAI (or any OpenAI-compatible endpoint)
# LLM_PROVIDER=openai
# ─────────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Other options: gpt-4o | gpt-4-turbo | o3-mini
#
# Optional: override base URL for proxies / compatible endpoints
# (e.g. LM Studio, Groq, Azure OpenAI, Ollama's OpenAI-compatible API)
# OPENAI_BASE_URL=http://localhost:1234/v1
